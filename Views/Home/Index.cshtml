@model SmartTrafficMonitor.Models.DashboardViewModel
@using SmartTrafficMonitor.Models

@{
    ViewData["Title"] = "Dashboard";

    var f = Model?.Filters ?? new TrafficFilterModel();

    string fmtDate(DateTime? dt)
    {
        if (!dt.HasValue) return "";
        // datetime-local expects "yyyy-MM-ddTHH:mm"
        return dt.Value.ToString("yyyy-MM-ddTHH:mm");
    }

    string boolToString(bool? b)
    {
        if (!b.HasValue) return "";
        return b.Value ? "true" : "false";
    }

    // Pretty sensor labels (slug -> Title Case)
    string prettySensor(string? slug)
    {
        if (string.IsNullOrWhiteSpace(slug)) return "—";

        // replace dash/underscore with space
        var s = slug.Replace("-", " ").Replace("_", " ").Trim();
        if (s.Length == 0) return "—";

        // basic title-case with a few overrides
        var parts = s.Split(' ', StringSplitOptions.RemoveEmptyEntries).ToArray();
        for (int i = 0; i < parts.Length; i++)
        {
            var w = parts[i].ToLowerInvariant();
            if (w == "st") parts[i] = "St";
            else if (w == "rd") parts[i] = "Rd";
            else if (w == "mt") parts[i] = "Mt";
            else if (w == "vu") parts[i] = "VU";
            else
            {
                parts[i] = char.ToUpper(parts[i][0]) + parts[i].Substring(1).ToLowerInvariant();
            }
        }

        return string.Join(" ", parts);
    }

    // Heatmap defaults (driven by filter model so it persists)
    var heatmapZone = string.IsNullOrWhiteSpace(f.Zone) ? "All" : f.Zone;
    var heatmapPeriod = string.IsNullOrWhiteSpace(f.HeatmapPeriod) ? "Weekly" : f.HeatmapPeriod;

    // Heatmap iframe src builder
    string buildHeatmapSrc()
    {
        var qs = new List<string>();

        qs.Add("zone=" + Uri.EscapeDataString(heatmapZone));
        qs.Add("period=" + Uri.EscapeDataString(heatmapPeriod));
        qs.Add("HeatmapPeriod=" + Uri.EscapeDataString(heatmapPeriod));

        if (!string.IsNullOrWhiteSpace(f.SensorId)) qs.Add("SensorId=" + Uri.EscapeDataString(f.SensorId));
        if (f.From.HasValue) qs.Add("From=" + Uri.EscapeDataString(f.From.Value.ToString("o")));
        if (f.To.HasValue) qs.Add("To=" + Uri.EscapeDataString(f.To.Value.ToString("o")));
        if (!string.IsNullOrWhiteSpace(f.MovementType)) qs.Add("MovementType=" + Uri.EscapeDataString(f.MovementType));
        if (!string.IsNullOrWhiteSpace(f.Season)) qs.Add("Season=" + Uri.EscapeDataString(f.Season));
        if (f.FootTrafficCount.HasValue) qs.Add("FootTrafficCount=" + f.FootTrafficCount.Value);
        if (f.VehicleCount.HasValue) qs.Add("VehicleCount=" + f.VehicleCount.Value);

        return "/Heatmap/View?" + string.Join("&", qs);
    }

    // Event impact link builder (prefill zone + date)
    string buildEventImpactHref()
    {
        var qs = new List<string>();

        if (!string.IsNullOrWhiteSpace(heatmapZone)) qs.Add("zone=" + Uri.EscapeDataString(heatmapZone));
        qs.Add("date=" + Uri.EscapeDataString(DateTime.Today.ToString("yyyy-MM-dd")));

        return "/EventImpact" + (qs.Count > 0 ? "?" + string.Join("&", qs) : "");
    }

    // -------- Pagination window logic (prevents huge number grid) --------
    int currentPage = Model?.Page ?? 1;
    int totalPages = Model?.TotalPages ?? 1;

    int window = 4; // shows current +/- 4 (so up to 9 page numbers)
    int startPage = Math.Max(1, currentPage - window);
    int endPage = Math.Min(totalPages, currentPage + window);

    // expand window if near edges
    if (currentPage <= window)
    {
        endPage = Math.Min(totalPages, 1 + (window * 2));
    }
    if (currentPage + window > totalPages)
    {
        startPage = Math.Max(1, totalPages - (window * 2));
    }
}

<div class="container mt-4 stm-body stm-dashboard">

    <div class="mb-3 stm-page-head">
        <h3 class="stm-title" style="margin-top:0;">Smart Foot Traffic Monitor Dashboard</h3>
        <p class="stm-subtitle" style="margin-bottom:0;">
            Filter traffic data, preview heatmap output, and page through results
        </p>

        @if (Model != null && Model.ShowFallbackWarning)
        {
            <div class="alert alert-warning" style="margin-top:12px;">
                @Model.FallbackMessage
            </div>
        }
    </div>

    <div class="stm-kpi-grid" style="margin-bottom:14px;">
        <div class="stm-kpi-card">
            <div class="stm-kpi-label">Pedestrians</div>
            <div class="stm-kpi-value">@((Model?.KpiTotalFootTraffic ?? 0).ToString("N0"))</div>
        </div>
        <div class="stm-kpi-card">
            <div class="stm-kpi-label">Cyclists</div>
            <div class="stm-kpi-value">@((Model?.KpiTotalCyclists ?? 0).ToString("N0"))</div>
        </div>
        <div class="stm-kpi-card">
            <div class="stm-kpi-label">Vehicles</div>
            <div class="stm-kpi-value">@((Model?.KpiTotalVehicles ?? 0).ToString("N0"))</div>
        </div>
        <div class="stm-kpi-card">
            <div class="stm-kpi-label">Records</div>
            <div class="stm-kpi-value">@((Model?.KpiRecordCount ?? 0).ToString("N0"))</div>
        </div>
        <div class="stm-kpi-card">
            <div class="stm-kpi-label">Busiest Sensor</div>
            <div class="stm-kpi-value" style="font-size:18px;">@(prettySensor(Model?.KpiBusiestSensor))</div>
        </div>
        <div class="stm-kpi-card">
            <div class="stm-kpi-label">Peak Hour</div>
            <div class="stm-kpi-value" style="font-size:18px;">@(Model?.KpiPeakHour ?? "—")</div>
        </div>
    </div>

    <div class="panel panel-default stm-card">
        <div class="panel-heading stm-card-header">
            <div class="stm-card-header-left">
                <strong>Heatmap Preview</strong>
                <span class="stm-subtle">@heatmapZone · @heatmapPeriod</span>
            </div>
            <div class="stm-card-header-right">
                <a id="eventImpactLink" class="btn btn-primary stm-primary-btn" href="@buildEventImpactHref()">
                    Open Event Impact Simulator
                </a>
            </div>
        </div>

        <div class="panel-body">
            <form id="heatmapForm" class="row" data-heatmap-base="/Heatmap/View" style="margin-bottom:10px;">
                <div class="col-md-4">
                    <label for="HeatmapZone">Select Zone</label>
                    <select id="HeatmapZone" name="Zone" class="form-control">
                        <option value="All" selected="@(heatmapZone == "All" ? "selected" : null)">All</option>
                        <option value="VU Campus" selected="@(heatmapZone == "VU Campus" ? "selected" : null)">VU Campus</option>
                        <option value="Footscray City" selected="@(heatmapZone == "Footscray City" ? "selected" : null)">Footscray City</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label for="HeatmapPeriod">Select Time Period</label>
                    <select id="HeatmapPeriod" name="HeatmapPeriod" class="form-control">
                        <option value="Weekly" selected="@(heatmapPeriod == "Weekly" ? "selected" : null)">Weekly</option>
                        <option value="Monthly" selected="@(heatmapPeriod == "Monthly" ? "selected" : null)">Monthly</option>
                        <option value="Seasonal" selected="@(heatmapPeriod == "Seasonal" ? "selected" : null)">Seasonal</option>
                    </select>
                </div>

                <div class="col-md-4" style="padding-top:24px;">
                    <input type="hidden" id="Zone" name="Zone" value="@heatmapZone" />
                    <input type="hidden" id="HeatmapPeriodHidden" name="HeatmapPeriod" value="@heatmapPeriod" />
                    <button type="submit" class="btn btn-warning stm-accent-btn" style="width:100%;">Generate Heatmap</button>
                </div>
            </form>

            <iframe id="heatmapFrame"
                    src="@buildHeatmapSrc()"
                    style="width: 100%; height: 520px; border: 0; border-radius: 12px; overflow: hidden;">
            </iframe>
        </div>
    </div>

    <div class="panel panel-default stm-card">
        <div class="panel-heading stm-card-header">
            <div class="stm-card-header-left">
                <strong>Filters</strong>
            </div>
        </div>

        <div class="panel-body">
            <form method="get" action="@Url.Action("Index","Home")">
                <div class="row">
                    <div class="col-md-3">
                        <label for="SensorId">Sensor</label>
                        <select id="SensorId" name="SensorId" class="form-control">
                            <option value="" selected="@(string.IsNullOrWhiteSpace(f.SensorId) ? "selected" : null)">(any)</option>
                            @foreach (var s in (Model?.AvailableSensors ?? new List<string>()))
                            {
                                if (string.IsNullOrWhiteSpace(s)) { continue; }
                                <option value="@s" selected="@(f.SensorId == s ? "selected" : null)">@prettySensor(s)</option>
                            }
                        </select>
                        <div class="help-text">Pick a sensor to filter results.</div>
                    </div>

                    <div class="col-md-3">
                        <label for="From">Start Time</label>
                        <input type="datetime-local" id="From" name="From" class="form-control" value="@fmtDate(f.From)" />
                    </div>

                    <div class="col-md-3">
                        <label for="To">End Time</label>
                        <input type="datetime-local" id="To" name="To" class="form-control" value="@fmtDate(f.To)" />
                    </div>

                    <div class="col-md-3">
                        <label for="MovementType">Movement Type</label>
                        <select id="MovementType" name="MovementType" class="form-control">
                            <option value="" selected="@(string.IsNullOrWhiteSpace(f.MovementType) ? "selected" : null)">(any)</option>
                            <option value="Pedestrian" selected="@(f.MovementType == "Pedestrian" ? "selected" : null)">Pedestrian</option>
                            <option value="Vehicle" selected="@(f.MovementType == "Vehicle" ? "selected" : null)">Vehicle</option>
                            <option value="Cyclist" selected="@(f.MovementType == "Cyclist" ? "selected" : null)">Cyclist</option>
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3">
                        <label for="Season">Season</label>
                        <select id="Season" name="Season" class="form-control">
                            <option value="" selected="@(string.IsNullOrWhiteSpace(f.Season) ? "selected" : null)">(any)</option>
                            <option value="Summer" selected="@(f.Season == "Summer" ? "selected" : null)">Summer</option>
                            <option value="Autumn" selected="@(f.Season == "Autumn" ? "selected" : null)">Autumn</option>
                            <option value="Winter" selected="@(f.Season == "Winter" ? "selected" : null)">Winter</option>
                            <option value="Spring" selected="@(f.Season == "Spring" ? "selected" : null)">Spring</option>
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3">
                        <label for="FootTrafficCount">Min Foot Traffic</label>
                        <input type="number" id="FootTrafficCount" name="FootTrafficCount" class="form-control"
                               min="0" step="1" placeholder="(any)"
                               value="@(f.FootTrafficCount?.ToString() ?? "")" />
                        <div class="help-text">Shows rows with foot traffic greater than or equal to this value.</div>
                    </div>

                    <div class="col-md-3">
                        <label for="VehicleCount">Min Vehicle Count</label>
                        <input type="number" id="VehicleCount" name="VehicleCount" class="form-control"
                               min="0" step="1" placeholder="(any)"
                               value="@(f.VehicleCount?.ToString() ?? "")" />
                        <div class="help-text">Shows rows with vehicle count greater than or equal to this value.</div>
                    </div>

                    <div class="col-md-3">
                        <label for="PageSize">Rows Per Page</label>
                        <select id="PageSize" name="PageSize" class="form-control">
                            <option value="25" selected="@(f.PageSize == 25 ? "selected" : null)">25</option>
                            <option value="50" selected="@(f.PageSize == 50 ? "selected" : null)">50</option>
                            <option value="100" selected="@(f.PageSize == 100 ? "selected" : null)">100</option>
                        </select>
                    </div>

                    <div class="col-md-3" style="padding-top:24px;">
                        <a class="btn btn-default stm-secondary-btn" style="width:100%;" href="@Url.Action("Index","Home")">Reset</a>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary stm-primary-btn" style="width:100%;">Apply Filters</button>
                    </div>
                    <div class="col-md-10 text-muted" style="padding-top: 8px;">
                        @if (Model != null)
                        {
                            <span>Matches: <strong>@Model.TotalCount</strong></span>
                            <span class="text-muted"> &nbsp; (showing @(Model.Results?.Count ?? 0) on this page)</span>
                        }
                    </div>
                </div>

            </form>
        </div>
    </div>

    <div class="panel panel-default stm-card">
        <div class="panel-heading stm-card-header">
            <div class="stm-card-header-left">
                <strong>Results</strong>
                @if (Model != null)
                {
                    <span class="stm-subtle">showing @Model.PageSize of @Model.TotalCount records</span>
                }
            </div>

            <div class="stm-card-header-right">
                <form id="exportForm" method="get" action="/api/export" class="stm-export">
                    <input type="hidden" name="SensorId" value="@(f.SensorId ?? "")" />
                    <input type="hidden" name="From" value="@fmtDate(f.From)" />
                    <input type="hidden" name="To" value="@fmtDate(f.To)" />
                    <input type="hidden" name="MovementType" value="@(f.MovementType ?? "")" />
                    <input type="hidden" name="Season" value="@(f.Season ?? "")" />
                    <input type="hidden" name="FootTrafficCount" value="@(f.FootTrafficCount?.ToString() ?? "")" />
                    <input type="hidden" name="VehicleCount" value="@(f.VehicleCount?.ToString() ?? "")" />
                    <input type="hidden" name="Zone" value="@heatmapZone" />
                    <input type="hidden" name="HeatmapPeriod" value="@heatmapPeriod" />

                    <select id="ExportFormat" name="ExportFormat" class="form-control stm-export-select">
                        <option value="csv">CSV</option>
                        <option value="pdf">PDF</option>
                    </select>

                    <button type="submit" class="btn btn-default stm-export-btn">Export</button>
                </form>
            </div>
        </div>

        <div class="panel-body" style="padding-top:0;">
            <div class="table-responsive">
                <table class="table table-striped stm-table">
                    <thead>
                        <tr>
                            <th>Sensor</th>
                            <th>Timestamp</th>
                            <th>Movement</th>
                            <th>Season</th>
                            <th>Foot Traffic</th>
                            <th>Vehicles</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in (Model?.Results ?? new List<TrafficData>()))
                        {
                            <tr>
                                <td>@prettySensor(r.SensorId)</td>
                                <td>@r.Timestamp.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@(r.MovementType ?? "")</td>
                                <td>@(r.Season ?? "")</td>
                                <td>@r.FootTrafficCount</td>
                                <td>@r.VehicleCount</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model != null && Model.TotalPages > 1)
            {
                <nav aria-label="Page navigation" style="text-align:center;">
                    <ul class="pagination stm-pagination">

                        <li class="@(Model.Page <= 1 ? "disabled" : "")">
                            <a asp-action="Index"
                               asp-controller="Home"
                               asp-route-Page="@(Model.Page - 1)"
                               asp-route-PageSize="@Model.PageSize"
                               asp-route-SensorId="@f.SensorId"
                               asp-route-From="@fmtDate(f.From)"
                               asp-route-To="@fmtDate(f.To)"
                               asp-route-MovementType="@f.MovementType"
                               asp-route-Season="@f.Season"
                               asp-route-FootTrafficCount="@f.FootTrafficCount"
                               asp-route-VehicleCount="@f.VehicleCount">
                                «
                            </a>
                        </li>

                        @if (startPage > 1)
                        {
                            <li class="@(1 == currentPage ? "active" : "")">
                                <a asp-action="Index"
                                   asp-controller="Home"
                                   asp-route-Page="1"
                                   asp-route-PageSize="@Model.PageSize"
                                   asp-route-SensorId="@f.SensorId"
                                   asp-route-From="@fmtDate(f.From)"
                                   asp-route-To="@fmtDate(f.To)"
                                   asp-route-MovementType="@f.MovementType"
                                   asp-route-Season="@f.Season"
                                   asp-route-FootTrafficCount="@f.FootTrafficCount"
                                   asp-route-VehicleCount="@f.VehicleCount">
                                    1
                                </a>
                            </li>

                            @if (startPage > 2)
                            {
                                <li class="disabled"><span>…</span></li>
                            }
                        }

                        @for (int p = startPage; p <= endPage; p++)
                        {
                            <li class="@(p == currentPage ? "active" : "")">
                                <a asp-action="Index"
                                   asp-controller="Home"
                                   asp-route-Page="@p"
                                   asp-route-PageSize="@Model.PageSize"
                                   asp-route-SensorId="@f.SensorId"
                                   asp-route-From="@fmtDate(f.From)"
                                   asp-route-To="@fmtDate(f.To)"
                                   asp-route-MovementType="@f.MovementType"
                                   asp-route-Season="@f.Season"
                                   asp-route-FootTrafficCount="@f.FootTrafficCount"
                                   asp-route-VehicleCount="@f.VehicleCount">
                                    @p
                                </a>
                            </li>
                        }

                        @if (endPage < totalPages)
                        {
                            @if (endPage < totalPages - 1)
                            {
                                <li class="disabled"><span>…</span></li>
                            }

                            <li class="@(totalPages == currentPage ? "active" : "")">
                                <a asp-action="Index"
                                   asp-controller="Home"
                                   asp-route-Page="@totalPages"
                                   asp-route-PageSize="@Model.PageSize"
                                   asp-route-SensorId="@f.SensorId"
                                   asp-route-From="@fmtDate(f.From)"
                                   asp-route-To="@fmtDate(f.To)"
                                   asp-route-MovementType="@f.MovementType"
                                   asp-route-Season="@f.Season"
                                   asp-route-FootTrafficCount="@f.FootTrafficCount"
                                   asp-route-VehicleCount="@f.VehicleCount">
                                    @totalPages
                                </a>
                            </li>
                        }

                        <li class="@(Model.Page >= Model.TotalPages ? "disabled" : "")">
                            <a asp-action="Index"
                               asp-controller="Home"
                               asp-route-Page="@(Model.Page + 1)"
                               asp-route-PageSize="@Model.PageSize"
                               asp-route-SensorId="@f.SensorId"
                               asp-route-From="@fmtDate(f.From)"
                               asp-route-To="@fmtDate(f.To)"
                               asp-route-MovementType="@f.MovementType"
                               asp-route-Season="@f.Season"
                               asp-route-FootTrafficCount="@f.FootTrafficCount"
                               asp-route-VehicleCount="@f.VehicleCount">
                                »
                            </a>
                        </li>

                    </ul>
                </nav>
            }
        </div>
    </div>

</div>

<script>
    (function () {
        const heatmapForm = document.getElementById('heatmapForm');
        const zoneSelect = document.getElementById('HeatmapZone');
        const periodSelect = document.getElementById('HeatmapPeriod');
        const frame = document.getElementById('heatmapFrame');
        const zoneHidden = document.getElementById('Zone');
        const periodHidden = document.getElementById('HeatmapPeriodHidden');
        const eventImpactLink = document.getElementById('eventImpactLink');

        if (!heatmapForm || !zoneSelect || !periodSelect || !frame) return;

        function getVal(id) {
            const el = document.getElementById(id);
            return el ? (el.value || '').trim() : '';
        }

        function append(qs, key, value) {
            if (!value) return;
            qs.push(encodeURIComponent(key) + '=' + encodeURIComponent(value));
        }

        function buildHeatmapUrl() {
            const base = heatmapForm.getAttribute('data-heatmap-base') || '/Heatmap/View';
            const zone = (zoneSelect.value || '').trim();
            const period = (periodSelect.value || '').trim();

            const qs = [];
            append(qs, 'zone', zone);
            append(qs, 'period', period);
            append(qs, 'HeatmapPeriod', period);
            append(qs, 'SensorId', getVal('SensorId'));
            append(qs, 'From', getVal('From'));
            append(qs, 'To', getVal('To'));
            append(qs, 'MovementType', getVal('MovementType'));
            append(qs, 'Season', getVal('Season'));
            append(qs, 'FootTrafficCount', getVal('FootTrafficCount'));
            append(qs, 'VehicleCount', getVal('VehicleCount'));

            return base + '?' + qs.join('&');
        }

        function syncHiddenState() {
            const zone = (zoneSelect.value || '').trim();
            const period = (periodSelect.value || '').trim();
            if (zoneHidden) zoneHidden.value = zone;
            if (periodHidden) periodHidden.value = period;
        }

        function syncEventImpactLink() {
            if (!eventImpactLink) return;
            const zone = (zoneSelect.value || '').trim();
            const date = new Date();
            const yyyy = date.getFullYear();
            const mm = String(date.getMonth() + 1).padStart(2, '0');
            const dd = String(date.getDate()).padStart(2, '0');
            const qs = [];
            append(qs, 'zone', zone);
            append(qs, 'date', `${yyyy}-${mm}-${dd}`);
            eventImpactLink.href = '/EventImpact?' + qs.join('&');
        }

        heatmapForm.addEventListener('submit', function (e) {
            e.preventDefault();
            syncHiddenState();
            syncEventImpactLink();
            frame.src = buildHeatmapUrl();
        });

        zoneSelect.addEventListener('change', function () { syncHiddenState(); syncEventImpactLink(); });
        periodSelect.addEventListener('change', function () { syncHiddenState(); syncEventImpactLink(); });

        syncHiddenState();
        syncEventImpactLink();
    })();
</script>