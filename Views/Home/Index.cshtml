@{
    ViewData["Title"] = "Home Page";

    // Pull current values from the querystring (safe even if missing)
    string q(string name) => Context.Request.Query[name].ToString();
    var qSensorId = q("SensorId");
    var qFrom = q("From");
    var qTo = q("To");
    var qMovementType = q("MovementType");
    var qSeason = q("Season");
    var qPt = q("PublicTransportRef");
    var qVu = q("VUScheduleRef");
}

<div class="container mt-4">
    <!-- FILTERS -> reload Index with results -->
    <form id="filterForm" method="get" action="@Url.Action("Index","Home")">
        <!-- FIRST ROW -->
        <div class="row g-4">
            <div class="col-md-3">
                <label for="SensorId">Sensor ID:</label>
                <input type="number" id="SensorId" name="SensorId" class="form-control" value="@qSensorId" />
            </div>

            <div class="col-md-3">
                <label for="From">Start Time:</label>
                <input type="datetime-local" id="From" name="From" class="form-control" value="@qFrom" />
            </div>

            <div class="col-md-3">
                <label for="To">End Time:</label>
                <input type="datetime-local" id="To" name="To" class="form-control" value="@qTo" />
            </div>

            <div class="col-md-3">
                <label for="MovementType">Movement Type:</label>
                <select id="MovementType" name="MovementType" class="form-control">
                    <option value="">(Any)</option>
                    <option value="Pedestrian" selected="@(qMovementType=="Pedestrian" ? "selected" : null)">Pedestrian</option>
                    <option value="Vehicle"    selected="@(qMovementType=="Vehicle"    ? "selected" : null)">Vehicle</option>
                    <option value="Cyclist"    selected="@(qMovementType=="Cyclist"    ? "selected" : null)">Cyclist</option>
                </select>
            </div>
        </div>

        <!-- SECOND ROW -->
        <div class="row g-4 mt-2">

            <div class="col-md-3">
                <label for="Season">Season:</label>
                <select id="Season" name="Season" class="form-control">
                    <option value="">(Any)</option>
                    <option value="Summer" selected="@(qSeason=="Summer" ? "selected" : null)">Summer</option>
                    <option value="Autumn" selected="@(qSeason=="Autumn" ? "selected" : null)">Autumn</option>
                    <option value="Winter" selected="@(qSeason=="Winter" ? "selected" : null)">Winter</option>
                    <option value="Spring" selected="@(qSeason=="Spring" ? "selected" : null)">Spring</option>
                </select>
            </div>

            <div class="col-md-3">
                <label for="PublicTransportRef">Transport Nearby:</label>
                <select id="PublicTransportRef" name="PublicTransportRef" class="form-control">
                    <option value="">(Any)</option>
                    <option value="true"  selected="@(qPt=="true"  ? "selected" : null)">Yes</option>
                    <option value="false" selected="@(qPt=="false" ? "selected" : null)">No</option>
                </select>
            </div>

            <div class="col-md-3">
                <label for="VUScheduleRef">Near VU Schedule:</label>
                <select id="VUScheduleRef" name="VUScheduleRef" class="form-control">
                    <option value="">(Any)</option>
                    <option value="true"  selected="@(qVu=="true"  ? "selected" : null)">Yes</option>
                    <option value="false" selected="@(qVu=="false" ? "selected" : null)">No</option>
                </select>
            </div>
        </div>

        <!-- BUTTON ROW -->
        <div class="row g-3 mt-3">
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Apply Filters</button>
            </div>
        </div>
    </form>

    <!-- EXPORT (reuses current filters) -->
    <form id="exportForm" class="form-inline mt-3" method="get" action="/api/export">
        <!-- Hidden fields copied from filterForm on submit -->
        <input type="hidden" name="SensorId" />
        <input type="hidden" name="From" />
        <input type="hidden" name="To" />
        <input type="hidden" name="MovementType" />
        <input type="hidden" name="Direction" />
        <input type="hidden" name="Season" />
        <input type="hidden" name="PublicTransportRef" />
        <input type="hidden" name="VUScheduleRef" />

        <div class="row g-3">
            <div class="col-md-3">
                <label for="ExportFormat">Export Format</label>
                <select id="ExportFormat" name="ExportFormat" class="form-control w-100">
                    <option value="csv">CSV</option>
                    <option value="pdf">PDF</option>
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-outline-secondary w-100">Export Report</button>
            </div>
        </div>
    </form>

    <!-- HEATMAP -->
    <form id="heatmapForm" class="form-inline mt-5">
        <div class="row g-3">
            <div class="col-md-4">
                <label for="HeatmapZone">Select Zone:</label>
                <select id="HeatmapZone" class="form-control">
                    <option value="Footscray Park">Footscray Park</option>
                    <option value="VU Campus">VU Campus</option>
                </select>
            </div>

            <div class="col-md-4">
                <label for="HeatmapPeriod">Select Time Period:</label>
                <select id="HeatmapPeriod" class="form-control">
                    <option value="Weekly">Weekly</option>
                    <option value="Monthly">Monthly</option>
                    <option value="Seasonal">Seasonal</option>
                </select>
            </div>

            <div class="col-md-4 d-flex align-items-end">
                <button type="submit" class="btn btn-warning w-100">Generate Heatmap</button>
            </div>
        </div>
    </form>

    <!-- HEATMAP PREVIEW -->
    <div class="mt-4">
        <h4>Heatmap Preview</h4>
        <iframe id="heatmapFrame" src="" width="100%" height="500" style="border:1px solid #ccc;"></iframe>
    </div>

    <div class="summary-box mt-4">
        <h4>SUMMARY</h4>
        <p>
            This dashboard helps visualize traffic patterns across Footscray using Smart Sensors. You can filter data, generate heatmaps, and export reports.
        </p>
        <ul>
            <li>Real-time and historical traffic insights</li>
            <li>Interactive heatmap visualization</li>
            <li>Export reports in CSV or PDF format</li>
            <li>Zone-based and seasonal traffic analysis</li>
        </ul>
    </div>
</div>

@section Scripts {
<script>
    // Copy filter values into export form before submit
    document.getElementById('exportForm').addEventListener('submit', function (e) {
        const src = document.getElementById('filterForm');
        const dst = e.target;

        const fields = ["SensorId","From","To","MovementType","Direction","Season","PublicTransportRef","VUScheduleRef"];
        fields.forEach(name => {
            const srcEl = src.querySelector(`[name="${name}"]`);
            const dstEl = dst.querySelector(`input[name="${name}"]`);
            if (srcEl && dstEl) dstEl.value = srcEl.value;
        });
    });

    // Heatmap: use exact param names to match TrafficFilterModel
    document.getElementById('heatmapForm').addEventListener('submit', function (e) {
        e.preventDefault();
        var Zone = document.getElementById('HeatmapZone').value;
        var HeatmapPeriod = document.getElementById('HeatmapPeriod').value;
        var params = new URLSearchParams({ Zone, HeatmapPeriod }).toString();
        document.getElementById('heatmapFrame').src = `/api/heatmap?${params}`;
    });
</script>
}
