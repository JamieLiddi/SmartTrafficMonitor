@{
    ViewData["Title"] = "Contact";
}

<div class="container" style="max-width: 980px;">
    <div class="mt-4 mb-4">
        <h1 class="display-4" style="font-weight: 600;">Contact</h1>
        <p class="lead mb-0">
            Need a report, data access, or help using the dashboard?
        </p>
    </div>

    <hr />

    <div class="row">
        <!-- LEFT SIDE -->
        <div class="col-md-7 mb-4">
            <h3 style="font-weight: 600;">Project Contacts</h3>
            <p class="text-muted" style="margin-bottom: 16px;">
                Contact either team member below and we will help direct your request.
            </p>

            <div class="row">
                <div class="col-sm-6" style="margin-bottom: 16px;">
                    <div class="panel panel-default stm-card" style="height: 100%;">
                        <div class="panel-body">
                            <div style="font-weight: 600; font-size: 16px;">
                                Jamie Liddicoat
                            </div>
                            <div class="text-muted" style="font-size: 12px; margin-top: 2px;">
                                Team Member
                            </div>

                            <hr style="border-color: rgba(255,255,255,0.08);" />

                            <div class="text-muted" style="font-size: 12px;">
                                Email
                            </div>
                            <div style="font-size: 14px; font-weight: 600; margin-top: 4px;">
                                <a href="mailto:s8107062@live.vu.edu.au" style="color: inherit; text-decoration: none;">
                                    s8107062@live.vu.edu.au
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-sm-6" style="margin-bottom: 16px;">
                    <div class="panel panel-default stm-card" style="height: 100%;">
                        <div class="panel-body">
                            <div style="font-weight: 600; font-size: 16px;">
                                Ethan O'Neil
                            </div>
                            <div class="text-muted" style="font-size: 12px; margin-top: 2px;">
                                Team Member
                            </div>

                            <hr style="border-color: rgba(255,255,255,0.08);" />

                            <div class="text-muted" style="font-size: 12px;">
                                Email
                            </div>
                            <div style="font-size: 14px; font-weight: 600; margin-top: 4px;">
                                <a href="mailto:s8087729@live.vu.edu.au" style="color: inherit; text-decoration: none;">
                                    s8087729@live.vu.edu.au
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="panel panel-default stm-card" style="margin-top: 8px;">
                <div class="panel-body">
                    <div style="font-weight: 600; margin-bottom: 6px;">General Enquiries</div>
                    <p class="text-muted" style="margin-bottom: 0;">
                        For questions about reports, filtered traffic data, exports, or general system support,
                        please email one of the contacts above with a short description of your request.
                    </p>
                </div>
            </div>
        </div>

        <!-- RIGHT SIDE -->
        <div class="col-md-5 mb-4">
            <h3 style="font-weight: 600;">Support Hours</h3>
            <ul class="list-unstyled" style="margin-bottom: 16px;">
                <li style="margin-bottom: 6px;"><strong>Mon–Fri:</strong> 9:00am–5:00pm</li>
                <li><strong>Weekends:</strong> By request</li>
            </ul>

            <h3 style="font-weight: 600;" class="mt-4">Privacy & Access</h3>
            <p class="mb-0 text-muted">
                Requests involving datasets, filtered exports, or restricted information may require
                confirmation of access permissions before they can be provided.
            </p>

            <div class="panel panel-default stm-card" style="margin-top: 14px;">
                <div class="panel-body">
                    <div style="font-weight: 600;">Location</div>
                    <p class="text-muted" style="margin: 8px 0 0;">
                        Victoria University, Footscray Park Campus
                    </p>
                </div>
            </div>

            <div class="panel panel-default stm-card" style="margin-top: 14px;">
                <div class="panel-body">
                    <div style="font-weight: 600;">Response Note</div>
                    <p class="text-muted" style="margin: 8px 0 0;">
                        Response times may vary depending on the complexity of the request and whether
                        data validation or approval is required.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>