@{
    ViewData["Title"] = "Contact";
}

<div class="container" style="max-width: 980px;">
    <div class="mt-4 mb-4">
        <h1 class="display-4" style="font-weight: 600;">Contact</h1>
        <p class="lead mb-0">
            Need a report, data access, or help using the dashboard.
        </p>
    </div>

    <hr />

    <div class="row">
        <div class="col-md-7 mb-4">
            <h3 style="font-weight: 600;">Project Contacts</h3>
            <p class="text-muted" style="margin-bottom: 12px;">
                Contact either person and we will handle it.
            </p>

            <div class="row">
                <div class="col-sm-6" style="margin-bottom: 12px;">
                    <div class="panel panel-default stm-card">
                        <div class="panel-body">
                            <div style="font-weight:600; font-size:16px;">
                                Jamie Liddicoat
                            </div>
                            <div class="text-muted" style="font-size:12px; margin-top:2px;">
                                Team Member
                            </div>

                            <hr style="border-color: rgba(255,255,255,0.08);" />

                            <div style="font-size:12px;" class="text-muted">
                                Email
                            </div>
                            <div style="font-size:14px; font-weight:600;">
                                s8107062@live.vu.edu.au
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-sm-6" style="margin-bottom: 12px;">
                    <div class="panel panel-default stm-card">
                        <div class="panel-body">
                            <div style="font-weight:600; font-size:16px;">
                                Ethan O'Neil
                            </div>
                            <div class="text-muted" style="font-size:12px; margin-top:2px;">
                                Team Member
                            </div>

                            <hr style="border-color: rgba(255,255,255,0.08);" />

                            <div style="font-size:12px;" class="text-muted">
                                Email
                            </div>
                            <div style="font-size:14px; font-weight:600;">
                                s8087729@live.vu.edu.au
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="panel panel-default stm-card" style="margin-top: 12px;">
                <div class="panel-body">
                    <div style="font-weight:600;">Notes</div>
                    <p class="text-muted" style="margin: 8px 0 0;">
                        If you are requesting an export, include date range, zone, movement type, and whether you need CSV or PDF.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-5 mb-4">
            <h3 style="font-weight: 600;">Support Hours</h3>
            <ul class="list-unstyled" style="margin-bottom: 16px;">
                <li><strong>Mon–Fri:</strong> 9:00am–5:00pm</li>
                <li><strong>Weekends:</strong> By request</li>
            </ul>

            <h3 style="font-weight: 600;" class="mt-4">Privacy & Access</h3>
            <p class="mb-0">
                If your request involves anything with datasets or exports, we may need to confirm what you are allowed to access.
            </p>

            <div class="panel panel-default stm-card" style="margin-top: 14px;">
                <div class="panel-body">
                    <div style="font-weight:600;">Location</div>
                    <p class="text-muted" style="margin: 8px 0 0;">
                        Victoria University, Footscray Park Campus.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
